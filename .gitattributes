# Git LFS tracking for large model binaries, should any be committed locally.
# Note: checkpoints are NOT committed here — they are hosted on Hugging Face.
# Figures (*.png) are small and committed as regular blobs, not via LFS.
*.pt        filter=lfs diff=lfs merge=lfs -text
*.pth       filter=lfs diff=lfs merge=lfs -text
*.ckpt      filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text
*.bin       filter=lfs diff=lfs merge=lfs -text

# Large data files
*.parquet   filter=lfs diff=lfs merge=lfs -text
*.arrow     filter=lfs diff=lfs merge=lfs -text
